{
  "multipart": [
    { "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_post" } },
    { "when": { "north": "true" }, "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_side", "uvlock": true } },
    { "when": { "east": "true" }, "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_side", "y": 90, "uvlock": true } },
    { "when": { "south": "true" }, "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_side_alt", "uvlock": true } },
