    { "when": { "north": "false" }, "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_noside" } },
    { "when": { "east": "false" }, "apply": { "model": "ewmedieval:block/tuff_carved_window_pane_noside_alt" } },
